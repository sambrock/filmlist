{
  "extends": "@filmlist/tsconfig/base.json",
  "compilerOptions": {
    "composite": true,
    "target": "ES2017",
    "skipLibCheck": true,
    "downlevelIteration": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
